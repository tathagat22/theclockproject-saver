{
  "productName": "The Clock Project",
  "identifier": "com.theclockproject.saver",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "The Clock Project",
        "width": 920,
        "height": 580,
        "minWidth": 820,
        "minHeight": 540,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
